# Example only — copy to terraform.tfvars (gitignored) and edit.
# Never commit terraform.tfvars if it contains sensitive CIDRs.

aws_region    = "us-east-1"
project_name  = "lootcodes-api"
environment   = "production"

ecr_repository_name = "lootcodes-api"
instance_type       = "t3.small"

# Required for a reachable public API unless you use a load balancer / private only.
# Replace with your public IP:  curl -s https://checkip.amazonaws.com
api_ingress_cidr_blocks = ["203.0.113.10/32"]

# Prefer false and use SSM Session Manager only.
enable_unrestricted_api_ingress = false

# Public API via Application Load Balancer.
# enable_https_alb               = true
# api_fqdn                       = "api.lootcodes.com"
# route53_zone_id                = "Zxxxxxxxxxxxx"  # optional if DNS is external
# create_route53_alias_for_api   = true            # false if DNS is outside Route53
# alb_redirect_http_to_https     = false
# create_alb_https_listener      = false   # set true after ACM validation CNAME + api hostname point at ALB
# When ALB is on, port 3000 is only open to the ALB — no need for wide api_ingress_cidr_blocks.
# alb_availability_zone_count  = 2   # min 2; fewer AZs => fewer ALB-managed "Elastic IPs" in EC2 console
# allocate_elastic_ip             = true   # ignored for EC2 EIP when ALB on unless alongside flag is true
# allocate_elastic_ip_alongside_alb = false  # set true only if you need a static IP direct to EC2 as well

associate_public_ip = true
deploy_directory    = "/opt/lootcodes-api"

# Must already exist in EC2 → Key pairs (same as your LootBoxy/Eneba.pem).
ec2_key_pair_name = "Eneba"

# Optional SSH (not recommended if using SSM); requires security group rule on 22.
# ssh_ingress_cidr_blocks = ["203.0.113.10/32"]
