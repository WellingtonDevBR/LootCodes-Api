# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Internal service auth (matches Edge Function INTERNAL_SERVICE_SECRET)
INTERNAL_SERVICE_SECRET=your-internal-secret
INTERNAL_SERVICE_SECRET_PREVIOUS=

# reCAPTCHA Enterprise
RECAPTCHA_PROJECT_ID=your-gcp-project-id
RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_API_KEY=your-api-key

# Resend (email)
RESEND_API_KEY=your-resend-key

# CORS
CORS_ORIGINS=https://lootcodes.com,https://www.lootcodes.com

# Site
SITE_URL=https://lootcodes.com
SITE_NAME=LootCodes

# Sentry (optional — omit SENTRY_DSN to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Algolia Search
ALGOLIA_APP_ID=
ALGOLIA_SEARCH_KEY=
ALGOLIA_INDEX_NAME=products
